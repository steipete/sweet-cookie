{
	"name": "sweet-cookie",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"check": "pnpm format:check && pnpm typecheck && pnpm lint",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"format:diff": "oxfmt --write . && git --no-pager diff",
		"lint": "oxlint --type-aware --tsconfig tsconfig.lint.json --config .oxlintrc.json .",
		"lint:fix": "oxlint --type-aware --tsconfig tsconfig.lint.json --config .oxlintrc.json --fix . && pnpm format",
		"test": "vitest run --coverage",
		"test:bun": "bun test packages/core/tests-bun",
		"test:watch": "vitest",
		"typecheck": "pnpm -r typecheck"
	},
	"devDependencies": {
		"@types/node": "^25.3.5",
		"@typescript/native-preview": "7.0.0-dev.20260503.1",
		"@vitest/coverage-v8": "^4.0.18",
		"oxfmt": "^0.36.0",
		"oxlint": "^1.51.0",
		"oxlint-tsgolint": "^0.16.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.25.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
